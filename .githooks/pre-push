#!/bin/sh
#
# Interim guardrail: block direct pushes to the protected branch.
#
# The qyne repos are on the GitHub free plan, where server-side branch protection
# is unavailable for private repos. Until GitHub Team is enabled (which replaces
# this with enforced protection), this client-side hook stops the common accident
# of pushing straight to main. All changes must land via PR.
#
# Enabled repo-wide by `git config core.hooksPath .githooks` (run automatically by
# the `prepare` script on `npm install`; see CONTRIBUTING.md).
#
# Emergency bypass (use only when you mean it): git push --no-verify

protected_branches="main"

while read -r _local_ref _local_sha remote_ref _remote_sha; do
	branch=${remote_ref#refs/heads/}
	for protected in $protected_branches; do
		if [ "$branch" = "$protected" ]; then
			echo "" >&2
			echo "  ✖ Direct push to '$protected' is blocked." >&2
			echo "    Open a PR from a feature branch instead:" >&2
			echo "      git switch -c feat/your-change" >&2
			echo "      git push -u origin feat/your-change" >&2
			echo "" >&2
			echo "    (emergency bypass: git push --no-verify)" >&2
			echo "" >&2
			exit 1
		fi
	done
done

exit 0
